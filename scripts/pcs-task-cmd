#!/usr/bin/env python3
"""
pcs-task-cmd — fetch a PCS ProdTask's submission artifact, or submit it.

Thin HTTP client over swf-monitor's REST API. No Django, no DB access.
The server regenerates from current PCS state on every call, so what
you print here reflects the task + dataset + config as they exist now.

Inspection mode (default; stdlib-only):
    pcs-task-cmd <name> --format {condor|panda|jedi|dump}

    # condor: bash one-liner (env-prefixed submit_csv.sh)
    # panda:  prun command
    # jedi:   JSON taskParamMap for Client.insertTaskParams()
    # dump:   full JSON view of the task + dataset + tags + config

Submission mode (one-command JEDI submit, requires pandaclient):
    pcs-task-cmd <name> --submit

    Fetches the taskParamMap, calls pandaclient.Client.insertTaskParams()
    using the operator's existing PanDA auth (proxy or OIDC token), then
    posts the resulting jediTaskID back to swf-monitor so PCS records the
    submission. Prints jediTaskID on success.

Env:
    SWFMON_URL    base URL, default https://epic-devcloud.org/prod
    SWFMON_TOKEN  optional DRF token (required if record-submission
                  endpoint is non-public on this deployment)
"""
import argparse
import json
import os
import re
import sys
import urllib.parse
import urllib.request


DEFAULT_URL = os.environ.get('SWFMON_URL', 'https://epic-devcloud.org/prod')


def _swfmon_request(method, url, body=None):
    """Make a swf-monitor request with optional token and JSON body."""
    data = None
    headers = {}
    if body is not None:
        data = json.dumps(body).encode('utf-8')
        headers['Content-Type'] = 'application/json'
    token = os.environ.get('SWFMON_TOKEN')
    if token:
        headers['Authorization'] = f'Token {token}'
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    return urllib.request.urlopen(req)


def _fetch_format(base_url, name, fmt):
    qs = urllib.parse.urlencode({'name': name, 'fmt': fmt})
    url = f'{base_url.rstrip("/")}/pcs/api/prod-tasks/command/?{qs}'
    with _swfmon_request('GET', url) as resp:
        return resp.read().decode()


def _record_submission(base_url, name, jedi_task_id, status='submitted'):
    qs = urllib.parse.urlencode({'name': name})
    url = f'{base_url.rstrip("/")}/pcs/api/prod-tasks/record-submission/?{qs}'
    with _swfmon_request('POST', url,
                         {'jedi_task_id': jedi_task_id, 'status': status}) as resp:
        return json.loads(resp.read().decode())


def _do_inspect(base_url, name, fmt):
    try:
        body = _fetch_format(base_url, name, fmt)
    except urllib.error.HTTPError as e:
        sys.stderr.write(f'HTTP {e.code}: {e.read().decode(errors="replace")}\n')
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(f'Request failed: {e.reason}\n')
        return 1
    sys.stdout.write(body)
    if sys.stdout.isatty():
        sys.stdout.write('\n')
    return 0


def _do_submit(base_url, name):
    # 1. Fetch taskParamMap from PCS.
    try:
        params_json = _fetch_format(base_url, name, 'jedi')
    except urllib.error.HTTPError as e:
        sys.stderr.write(f'PCS HTTP {e.code} fetching taskParamMap: '
                         f'{e.read().decode(errors="replace")}\n')
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(f'PCS request failed: {e.reason}\n')
        return 1
    try:
        task_params = json.loads(params_json)
    except json.JSONDecodeError as e:
        sys.stderr.write(f'Could not parse taskParamMap JSON: {e}\n')
        return 1

    # 2. Lazy-import pandaclient — only required for --submit path.
    try:
        from pandaclient import Client  # noqa: WPS433
    except ImportError as e:
        sys.stderr.write(
            f'pandaclient not importable ({e}). Install panda-client and '
            f'ensure your PanDA auth context (proxy or OIDC token) is live.\n'
        )
        return 1

    # 3. Submit to JEDI. Returns (comms_status, (inner_code, message)) on
    #    comms success; (255, output) on comms failure.
    try:
        comms_status, result = Client.insertTaskParams(task_params)
    except Exception as e:
        sys.stderr.write(f'Client.insertTaskParams raised: {e}\n')
        return 1
    if comms_status != 0:
        sys.stderr.write(f'PanDA comms failure (status={comms_status}): {result}\n')
        return 1
    try:
        inner_code, message = result
    except (TypeError, ValueError):
        sys.stderr.write(f'Unexpected response shape: {result}\n')
        return 1
    if inner_code != 0:
        sys.stderr.write(
            f'JEDI rejected submission: code={inner_code} msg={message}\n'
        )
        return 1

    # 4. Parse jediTaskID from message. Server-side message formats
    #    (panda-server/.../task_event_module.py):
    #      "succeeded. new jediTaskID=12345"
    #      "reactivation accepted. jediTaskID=12345 ..."
    #      "<status>. new tasks params have been set to jediTaskID=12345. "
    m = re.search(r'jediTaskID=(\d+)', message)
    if not m:
        sys.stderr.write(f'Could not parse jediTaskID from message: {message}\n')
        return 1
    jedi_task_id = int(m.group(1))

    # 5. Record back to PCS. If write-back fails we still surface the
    #    jediTaskID — submission succeeded, only PCS bookkeeping failed.
    try:
        _record_submission(base_url, name, jedi_task_id)
    except urllib.error.HTTPError as e:
        sys.stderr.write(
            f'Submitted to JEDI as jediTaskID={jedi_task_id}, but PCS '
            f'record-submission HTTP {e.code}: '
            f'{e.read().decode(errors="replace")}\n'
        )
        return 2
    except urllib.error.URLError as e:
        sys.stderr.write(
            f'Submitted to JEDI as jediTaskID={jedi_task_id}, but PCS '
            f'record-submission request failed: {e.reason}\n'
        )
        return 2

    sys.stdout.write(
        f'Submitted: jediTaskID={jedi_task_id} (PCS status=submitted)\n'
        f'  PanDA message: {message}\n'
    )
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(description=__doc__.strip().splitlines()[0])
    ap.add_argument('name', help='ProdTask name')
    mode = ap.add_mutually_exclusive_group(required=True)
    mode.add_argument('--format', choices=['condor', 'panda', 'jedi', 'dump'],
                      help='inspection mode: print submission artifact')
    mode.add_argument('--submit', action='store_true',
                      help='submission mode: send taskParamMap to JEDI '
                           'and record the resulting jediTaskID in PCS')
    ap.add_argument('--url', default=DEFAULT_URL,
                    help=f'swf-monitor base URL (default: {DEFAULT_URL})')
    args = ap.parse_args()

    if args.submit:
        return _do_submit(args.url, args.name)
    return _do_inspect(args.url, args.name, args.format)


if __name__ == '__main__':
    sys.exit(main())
