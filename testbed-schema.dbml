Table pcs.ProdTask {
  Note: '''
A production task: Dataset + ProdConfig + submission-specific params.
Fully defines a production submission from which Condor and PanDA
commands can be generated.


*DB table: pcs_prod_task*'''

  id big_auto [pk, unique, not null]
  name char [note: '''Task name (auto-derived from dataset or manual)''', unique, not null]
  description text [default:`""`, not null]
  status char [default:`"draft"`, not null]
  dataset_id foreign_key [not null]
  prod_config_id foreign_key [not null]
  campaign_id foreign_key [note: '''Campaign this task belongs to''', null]
  request_id foreign_key [note: '''Originating PWG/DSC request, if any''', null]
  requestor char [default:`""`, not null]
  priority integer [null]
  pre_tdr_use boolean [default:`False`, not null]
  early_science_use boolean [default:`False`, not null]
  other_use boolean [default:`False`, not null]
  new_request boolean [default:`False`, not null]
  csv_file char [note: '''CSV file path in simulation_campaign_datasets''', default:`""`, not null]
  overrides json [note: '''Per-task overrides of ProdConfig fields (JSON)''', null]
  condor_command text [note: '''Generated Condor submission command''', default:`""`, not null]
  panda_command text [note: '''Generated PanDA submission command''', default:`""`, not null]
  panda_task_id big_integer [note: '''PanDA task ID after submission''', null]
  condor_cluster_id char [note: '''Condor cluster ID after submission''', default:`""`, not null]
  created_by char [not null]
  created_at date_time [not null]
  updated_at date_time [not null]

  indexes {
    (campaign_id) [name: 'pcs_prod_task_campaign_id_4904c203', type: btree]
    (dataset_id) [name: 'pcs_prod_task_dataset_id_c973b6bd', type: btree]
    (name) [unique, name: 'pcs_prod_task_name_key', type: btree]
    (id) [pk, unique, name: 'pcs_prod_task_pkey', type: btree]
    (prod_config_id) [name: 'pcs_prod_task_prod_config_id_18763ab2', type: btree]
    (request_id) [name: 'pcs_prod_task_request_id_781faee0', type: btree]
  }
}
