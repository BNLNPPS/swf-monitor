Table monitor_app.Subscriber {
  Note: '''
Represents a message queue subscriber in the monitoring system. 
Subscribers receive notifications about STF files via ActiveMQ directly or SSE.

Attributes:
subscriber_id: Auto-incrementing primary key
subscriber_name: Unique name identifying the subscriber
fraction: Fraction of messages to receive  
description: Human-readable description of the subscriber
is_active: Whether the subscriber is currently active
created_at: Timestamp when record was created
updated_at: Timestamp when record was last updated
delivery_type: How messages are delivered (activemq or sse)
client_ip: IP address for SSE subscribers
client_location: Geographic location for SSE subscribers
connected_at: When SSE subscriber connected
disconnected_at: When SSE subscriber disconnected
last_activity: Last activity timestamp for SSE subscribers
message_filters: JSON filters for SSE message selection
messages_received: Count of messages received
messages_sent: Count of messages sent (SSE)
messages_dropped: Count of messages dropped due to queue overflow (SSE)


*table: public.swf_subscribers*'''

  subscriber_id auto [note: '''*subscriber id*''', pk, unique, not null]
  subscriber_name char [note: '''*subscriber name*''', unique, not null]
  fraction float [note: '''*fraction*''', null]
  description text [note: '''*description*''', null]
  is_active boolean [note: '''*is active*''', default:`True`, not null]
  created_at date_time [note: '''*created at*''', not null]
  updated_at date_time [note: '''*updated at*''', not null]
  delivery_type monitor_app.char_subscriber_delivery_type [note: '''*delivery type*''', default:`"activemq"`, not null]
  client_ip generic_ip_address [note: '''*client ip*''', null]
  client_location char [note: '''*client location*''', default:`""`, not null]
  connected_at date_time [note: '''*connected at*''', null]
  disconnected_at date_time [note: '''*disconnected at*''', null]
  last_activity date_time [note: '''*last activity*''', null]
  message_filters json [note: '''*message filters*''', default:`builtins.dict()`, not null]
  messages_received integer [note: '''*messages received*''', default:`0`, not null]
  messages_sent integer [note: '''*messages sent*''', default:`0`, not null]
  messages_dropped integer [note: '''*messages dropped*''', default:`0`, not null]

  indexes {
    (delivery_type,is_active) [name: 'swf_subscri_deliver_1836c2_idx', type: btree]
    (subscriber_id) [pk, unique, name: 'swf_subscribers_pkey', type: btree]
    (subscriber_name) [unique, name: 'swf_subscribers_subscriber_name_key', type: btree]
  }
}


Table monitor_app.SysConfig {
  Note: '''
Human-set system configuration as one JSON document.

Distinct from PersistentState, which is machine-maintained state
(counters, run numbers): SysConfig holds operator-adjustable knobs —
live-stream policy, sweep cadences, report settings — viewable and
editable on the System page. All system configuration lives here, in
the database, adjustable through the UI without deploys.


*table: public.swf_sys_config*'''

  id auto [note: '''*id*''', pk, unique, not null]
  config_data json [note: '''*config data*''', default:`builtins.dict()`, not null]
  updated_at date_time [note: '''*updated at*''', not null]
  updated_by char [note: '''*updated by*''', default:`""`, not null]

  indexes {
    (id) [pk, unique, name: 'swf_sys_config_pkey', type: btree]
  }
}


Table monitor_app.SystemAgent {
  Note: '''
SystemAgent(id, instance_name, agent_type, description, status, last_heartbeat, agent_url, workflow_enabled, current_stf_count, total_stf_processed, last_stf_processed, pid, hostname, operational_state, namespace, metadata, created_at, updated_at)

*table: public.swf_systemagent*'''

  id big_auto [note: '''*ID*''', pk, unique, not null]
  instance_name char [note: '''*instance name*''', unique, not null]
  agent_type monitor_app.char_systemagent_agent_type [note: '''*agent type*''', not null]
  description text [note: '''*description*''', not null]
  status monitor_app.char_systemagent_status [note: '''*status*''', default:`"UNKNOWN"`, not null]
  last_heartbeat date_time [note: '''*last heartbeat*''', null]
  agent_url url [note: '''*agent url*''', null]
  workflow_enabled boolean [note: '''*workflow enabled*''', default:`True`, not null]
  current_stf_count integer [note: '''*current stf count*''', default:`0`, not null]
  total_stf_processed integer [note: '''*total stf processed*''', default:`0`, not null]
  last_stf_processed date_time [note: '''*last stf processed*''', null]
  pid integer [note: '''
*pid*
Process ID for kill operations''', null]
  hostname char [note: '''
*hostname*
Host where agent is running''', null]
  operational_state monitor_app.char_systemagent_operational_state [note: '''
*operational state*
What the agent is doing (STARTING/READY/PROCESSING/EXITED)''', default:`"STARTING"`, not null]
  namespace char [note: '''
*namespace*
Testbed namespace for workflow delineation''', null]
  metadata json [note: '''
*metadata*
Extensible metadata for agent configuration and state''', null]
  created_at date_time [note: '''*created at*''', not null]
  updated_at date_time [note: '''*updated at*''', not null]

  indexes {
    (instance_name) [unique, name: 'swf_systemagent_instance_name_key', type: btree]
    (namespace) [name: 'swf_systemagent_namespace_095b5b2c', type: btree]
    (id) [pk, unique, name: 'swf_systemagent_pkey', type: btree]
  }
}


