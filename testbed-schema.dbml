Table monitor_app.TFSlice {
  Note: '''
Represents a Time Frame slice for fast processing workflow.
Each TF slice is a small portion (~15 per STF sample) that can be
processed independently by workers in ~30 seconds.


*table: public.swf_tf_slices*'''

  id big_auto [note: '''*ID*''', pk, unique, not null]
  slice_id integer [note: '''*slice id*''', not null]
  tf_first integer [note: '''*tf first*''', not null]
  tf_last integer [note: '''*tf last*''', not null]
  tf_count integer [note: '''*tf count*''', not null]
  tf_filename char [note: '''*tf filename*''', not null]
  stf_filename char [note: '''*stf filename*''', not null]
  run_number integer [note: '''*run number*''', not null]
  status char [note: '''*status*''', default:`"queued"`, not null]
  retries integer [note: '''*retries*''', default:`0`, not null]
  metadata json [note: '''*metadata*''', null]
  created_at date_time [note: '''*created at*''', not null]
  updated_at date_time [note: '''*updated at*''', not null]
  assigned_worker char [note: '''*assigned worker*''', null]
  assigned_at date_time [note: '''*assigned at*''', null]
  completed_at date_time [note: '''*completed at*''', null]

  indexes {
    (run_number,status) [name: 'swf_tf_slic_run_num_783be1_idx', type: btree]
    (status,created_at) [name: 'swf_tf_slic_status_a09d78_idx', type: btree]
    (stf_filename,status) [name: 'swf_tf_slic_stf_fil_45fc7b_idx', type: btree]
    (id) [pk, unique, name: 'swf_tf_slices_pkey', type: btree]
    (run_number) [name: 'swf_tf_slices_run_number_7f432352', type: btree]
    (stf_filename) [name: 'swf_tf_slices_stf_filename_013bb220', type: btree]
    (tf_filename) [name: 'swf_tf_slices_tf_filename_3fa6f280', type: btree]
    (tf_filename,slice_id) [unique, name: 'swf_tf_slices_tf_filename_slice_id_2ea501ba_uniq', type: btree]
  }
}


