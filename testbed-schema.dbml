  lifecycle char [default:`"future"`, not null]
  description text [default:`""`, not null]
  start_date date [null]
  end_date date [null]
  clone_of_id foreign_key [note: '''Campaign this was cloned from''', null]
  data json [note: '''Flexible extension fields (no migration to add new keys)''', default:`builtins.dict()`, not null]
  created_by char [not null]
  created_at date_time [not null]
  updated_at date_time [not null]

  indexes {
