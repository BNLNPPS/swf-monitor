Table pcs.ProdConfig {
  Note: '''
Production configuration template — mutable operational settings for job submission.

Captures everything needed to build a production submit command beyond what
the four tags and dataset already define: background mixing, output control,
software stack, resource targets, condor template, and PanDA/Rucio overrides.
Always mutable — the PanDA task/job spec is the immutable record.


*DB table: pcs_prod_config*'''

  id big_auto [pk, unique, not null]
  name char [note: '''Human-readable config name, e.g. "DVCS 10x100 standard"''', unique, not null]
  description text [default:`""`, not null]
  bg_mixing boolean [default:`False`, not null]
  bg_cross_section char [default:`""`, not null]
  bg_evtgen_file char [default:`""`, not null]
  copy_reco boolean [default:`True`, not null]
  copy_full boolean [default:`False`, not null]
  copy_log boolean [default:`True`, not null]
  use_rucio boolean [default:`True`, not null]
  jug_xl_tag char [note: '''e.g. 26.02.0-stable''', default:`""`, not null]
  container_image char [note: '''Singularity/Apptainer image reference''', default:`""`, not null]
  target_hours_per_job decimal [note: '''Target walltime per job in hours''', null]
  events_per_task positive_integer [note: '''Total events for the task''', null]
  condor_template text [note: '''HTCondor submission template''', default:`""`, not null]
  panda_site char [default:`""`, not null]
  panda_queue char [default:`""`, not null]
  panda_working_group char [default:`""`, not null]
  panda_resource_type char [default:`""`, not null]
  rucio_rse char [note: '''Rucio Storage Element for output''', default:`""`, not null]
  rucio_replication_rules json [note: '''Rucio replication rule definitions''', null]
  data json [note: '''Additional submission parameters (JSON)''', null]
  created_by char [not null]
  created_at date_time [not null]
  updated_at date_time [not null]

  indexes {
    (name) [unique, name: 'pcs_prod_config_name_key', type: btree]
    (id) [pk, unique, name: 'pcs_prod_config_pkey', type: btree]
  }
}


Table pcs.ProdRequest {
  Note: '''
PWG/DSC production request — upstream of ProdTask.

Captures the request spreadsheet fields, system fields for intake
idempotency and traceability, and production-team triage state.
Use flags and requestor are duplicated onto ProdTask at task
creation; both rows are mutable independently after that.


*DB table: pcs_prod_request*'''

  id big_auto [pk, unique, not null]
  questionnaire_id foreign_key [note: '''Originating Google Form response mirror, if linked''', null]
  requestor char [note: '''PWG or DSC making the request''', default:`""`, not null]
  simu_path char [note: '''Declared simulation/EVGEN input location''', default:`""`, not null]
  gen_config text [note: '''Generator configuration text from the request''', default:`""`, not null]
  nevents big_integer [note: '''Requested event count''', null]
  background char [note: '''Requested background condition''', default:`""`, not null]
  description text [default:`""`, not null]
  priority integer [note: '''Requester or production priority''', null]
  pre_tdr_use boolean [default:`False`, not null]
  early_science_use boolean [default:`False`, not null]
  other_use boolean [default:`False`, not null]
  new_request boolean [default:`False`, not null]
  status char [default:`"new"`, not null]
  source_url char [note: '''Source spreadsheet or form URL''', default:`""`, not null]
  source_row char [note: '''Source row identifier for idempotent import''', default:`""`, not null]
  input_status char [note: '''Whether declared inputs are located/registered/usable''', default:`""`, not null]
  rucio_source char [note: '''Rucio DID or container for registered input''', default:`""`, not null]
  validation_status char [note: '''Validation summary''', default:`""`, not null]
  data json [note: '''Flexible extension fields (no migration to add new keys)''', default:`builtins.dict()`, not null]
  created_by char [not null]
  created_at date_time [not null]
  updated_at date_time [not null]

  indexes {
    (id) [pk, unique, name: 'pcs_prod_request_pkey', type: btree]
    (questionnaire_id) [name: 'pcs_prod_request_questionnaire_id_01db2c3e', type: btree]
  }
}
