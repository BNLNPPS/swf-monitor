  campaign_id foreign_key [null]
  physics_tag_id foreign_key [not null]
  evgen_tag_id foreign_key [not null]
  simu_tag_id foreign_key [not null]
  reco_tag_id foreign_key [not null]
  background_tag_id foreign_key [null]
  sample_name char [default:`""`, not null]
  propagation pcs.char_dataset_propagation [default:`"continue"`, not null]
  replaced_by char [default:`""`, not null]
  block_num positive_integer [default:`1`, not null]
  blocks positive_integer [default:`1`, not null]
  did char [unique, not null]
  file_count integer [default:`0`, not null]
  data_size big_integer [default:`0`, not null]
  description text [default:`""`, not null]
  metadata json [null]
  created_by char [not null]
  created_at date_time [not null]

  indexes {
    (background_tag_id) [name: 'pcs_dataset_background_tag_id_2cf7bb33', type: btree]
    (campaign_id) [name: 'pcs_dataset_campaign_id_029de6cc', type: btree]
    (composed_name) [name: 'pcs_dataset_composed_name_bacc86bb', type: btree]
    (dataset_name,block_num) [unique, name: 'pcs_dataset_dataset_name_block_num_1e4cea76_uniq', type: btree]
    (did) [unique, name: 'pcs_dataset_did_key', type: btree]
    (evgen_tag_id) [name: 'pcs_dataset_evgen_tag_id_d087bbcb', type: btree]
