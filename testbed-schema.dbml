  replaced_by char [note: '''*replaced by*''', default:`""`, not null]
  block_num positive_integer [note: '''*block num*''', default:`1`, not null]
  blocks positive_integer [note: '''*blocks*''', default:`1`, not null]
  did char [note: '''*did*''', unique, not null]
  file_count integer [note: '''*file count*''', default:`0`, not null]
  data_size big_integer [note: '''*data size*''', default:`0`, not null]
  description text [note: '''*description*''', default:`""`, not null]
  metadata json [note: '''*metadata*''', null]
  created_by char [note: '''*created by*''', not null]
  created_at date_time [note: '''*created at*''', not null]

  indexes {
